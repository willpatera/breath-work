{
  "id": "box-breathing",
  "title": "Box Breathing",
  "author": "Open",
  "description": "Classic 4-4-4-4 box breathing. Equal duration inhale, hold, exhale, hold. Used by Navy SEALs and first responders for calm focus.",
  "steps": [
    {
      "type": "instruction",
      "label": "Settle in",
      "text": "Breathe normally",
      "duration": 10.0
    },
    {
      "type": "repeat",
      "label": "Main cycle",
      "rounds": 8,
      "sequence": [
        { "type": "inhale", "duration": 4.0 },
        { "type": "hold_in", "duration": 4.0 },
        { "type": "exhale", "duration": 4.0 },
        { "type": "hold_out", "duration": 4.0, "cues": { "countdown": [3, 2, 1] } }
      ]
    }
  ]
}
