      "sequence": [
        { "type": "inhale", "duration": 1.5 },
        { "type": "exhale", "duration": 1.5 }
      ]
    },
    { "type": "hold_out", "duration": 90.0, "cues": { "countdown": [10, 3, 2, 1] } },
    { "type": "inhale", "duration": 4.0 },
    { "type": "exhale", "duration": 4.0 },
    { "type": "hold_out", "duration": 30.0, "cues": { "countdown": [10, 3, 2, 1] } },
    {
      "type": "repeat",
      "label": "5.5 in / 5.5 out",
