      "sequence": [
        { "type": "inhale", "duration": 5.5 },
        { "type": "exhale", "duration": 5.5 }
      ]
    },
    { "type": "inhale", "duration": 21.0 },
    { "type": "exhale", "duration": 21.0 },
    { "type": "inhale", "duration": 13.0 },
    { "type": "exhale", "duration": 13.0 },
    { "type": "inhale", "duration": 8.0 },
    { "type": "exhale", "duration": 8.0 },
    { "type": "inhale", "duration": 5.0 },
    { "type": "exhale", "duration": 5.0 },
    { "type": "inhale", "duration": 3.0 },
    { "type": "exhale", "duration": 3.0 },
    { "type": "inhale", "duration": 2.0 },
    { "type": "exhale", "duration": 2.0 },
    { "type": "inhale", "duration": 1.0 },
    { "type": "exhale", "duration": 1.0 },
